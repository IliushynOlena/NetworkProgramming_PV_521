<Window x:Class="_02_MultyChatUDP_Protocol.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_02_MultyChatUDP_Protocol"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <DockPanel Margin="5">
        <DockPanel DockPanel.Dock="Top">
            <Label Padding="10">Message : </Label>
            <Button DockPanel.Dock="Right" Padding="10" Margin="5" 
                    Click="Send_Button_Click"
                    Background="Bisque">Send</Button>
            <Button DockPanel.Dock="Right" Padding="10" Margin="5"
                    Click="Connection_Button_Click">Connection</Button>
            <Button DockPanel.Dock="Right" Padding="10" Margin="5"
                    Click="Disconnect_Button_Click">Disconnect</Button>
            <TextBox Margin="5" Padding="5" 
                     VerticalContentAlignment="Center"
                     x:Name="msgTextBox"></TextBox>
        </DockPanel>
        <TextBlock DockPanel.Dock="Top" TextAlignment="Center"
                   FontSize="20" FontWeight="Bold">Chat </TextBlock>
        <ListBox ItemsSource="{Binding}"></ListBox>

    </DockPanel>
</Window>
